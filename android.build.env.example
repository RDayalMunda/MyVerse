# Copy this file to android.build.env and fill in your machine-specific paths.
# android.build.env is gitignored — never commit it.
#
# BEFORE editing this file, complete docs/BUILD_ANDROID.md steps 1–5:
#   JDK 17, Android SDK, release keystore, .env.production
# Then run: npm run build:apk:setup

# --- JDK (required: JDK 17 recommended) ---
# Folder that contains bin/java.exe — NOT bundletool, NOT Android Studio.
# The setup wizard asks for this as "JAVA_HOME".
# Windows example:
# JAVA_HOME=C:\Program Files\Java\jdk-17
# macOS example:
# JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home

JAVA_HOME=

# --- Android SDK (from Android Studio) ---
# Folder that contains platform-tools/, build-tools/, platforms/.
# The setup wizard asks for this as "ANDROID_HOME".
# Find it in Android Studio: Settings → Android SDK → "Android SDK Location"
# Windows example:
# ANDROID_HOME=D:\Android
# ANDROID_HOME=C:\Users\you\AppData\Local\Android\Sdk
# macOS example:
# ANDROID_HOME=/Users/you/Library/Android/sdk

ANDROID_HOME=

# --- Release keystore (REQUIRED — create BEFORE setup; see docs/BUILD_ANDROID.md Step 4) ---
# Generate with:
#   keytool -genkeypair -v -keystore keystore/myverse-release.keystore -alias myverse -keyalg RSA -keysize 2048 -validity 10000
# Remember the password — you need it every build.
KEYSTORE_PATH=./keystore/myverse-release.keystore
KEYSTORE_ALIAS=myverse

# Passwords: leave blank to be prompted at build time (recommended).
# KEYSTORE_PASSWORD=
# KEY_PASSWORD=

# --- Output ---
OUTPUT_DIR=./dist

# --- Optional: AAB + bundletool path (only for npm run build:apk -- --bundle) ---
# Download from https://github.com/google/bundletool/releases
# BUNDLETOOL_JAR=./tools/bundletool-all.jar
